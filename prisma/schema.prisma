// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Usuarios del sistema
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(VIEWER)
  roleExpiration DateTime?
  roleAnterior Role?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  movimientosBodega    MovimientoBodega[]
  movimientosFarmacia  MovimientoFarmacia[]
  solicitudesCreadas   SolicitudVehiculo[]  @relation("CreadoPorFlota")
  solicitudesAprobadas SolicitudVehiculo[]  @relation("AprobacionFlota")
  solicitudesCerradas  SolicitudVehiculo[]  @relation("CierreFlota")
  ordenesFlota         OrdenServicioFlota[] @relation("FirmaOrdenFlota")
  documentosFlota      DocumentoVehiculo[]
  hojaVidaFlota        HojaVidaVehiculo[]
  mantencionesFlota    MantencionVehiculo[]
  observacionesCreadas ObservacionVehiculo[] @relation("CreadorObservacion")
  observacionesCerradas ObservacionVehiculo[] @relation("CierreObservacion")
  notasObservacion     ObservacionNota[]
  archivosObservacion  ObservacionArchivo[]
  conductorFlota       ConductorFlota?
}

enum Role {
  ADMIN
  BODEGA
  FARMACIA
  FLOTA
  ENCARGADO
  VIEWER
}

// ─── MÓDULO BODEGA MUNICIPAL ───────────────────────────

model CategoriaBodega {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  productos ProductoBodega[]

  historial ProductoBodegaHistorial[]
}

model ProductoBodega {
  id          Int             @id @default(autoincrement())
  codigo      String          @unique
  nombre      String
  descripcion String?
  unidad      String
  stockActual Int             @default(0)
  stockMinimo Int             @default(0)
  categoria   CategoriaBodega @relation(fields: [categoriaId], references: [id])
  categoriaId Int
  activo      Boolean         @default(true)
  createdAt   DateTime        @default(now())

  movimientos MovimientoBodega[]

  historial ProductoBodegaHistorial[]
}

model MovimientoBodega {
  id          Int              @id @default(autoincrement())
  tipo        TipoMovimiento
  cantidad    Int
  documento   TipoDocumento
  numeroDocumento String?
  proveedor   String?
  destinatario String?
  area        String?
  observacion String?
  fecha       DateTime         @default(now())
  producto    ProductoBodega   @relation(fields: [productoId], references: [id])
  productoId  Int
  usuario     User             @relation(fields: [usuarioId], references: [id])
  usuarioId   Int

  anulado     Boolean          @default(false)
  motivoAnulacion String?
  anulacionDeId Int?           @unique
  anulacionDe MovimientoBodega? @relation("AnulacionBodega", fields: [anulacionDeId], references: [id])
  anulacion   MovimientoBodega? @relation("AnulacionBodega")
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE
}

enum TipoDocumento {
  ORDEN_COMPRA
  FACTURA
  GUIA_DESPACHO
  NOTA_DEBITO
  NOTA_CREDITO
  ACTA_DONACION
  SIN_DOCUMENTO
  OTRO
}

// ─── MÓDULO FARMACIA POSTA ─────────────────────────────

model CategoriaFarmacia {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  medicamentos Medicamento[]

  historial MedicamentoHistorial[]
}

model Medicamento {
  id               Int               @id @default(autoincrement())
  codigo           String            @unique
  nombreGenerico   String
  nombreComercial  String?
  formaFarmaceutica String
  concentracion    String?
  unidad           String
  stockActual      Int               @default(0)
  stockMinimo      Int               @default(0)
  categoria        CategoriaFarmacia @relation(fields: [categoriaId], references: [id])
  categoriaId      Int
  activo           Boolean           @default(true)
  createdAt        DateTime          @default(now())

  movimientos MovimientoFarmacia[]

  historial MedicamentoHistorial[]

  lotes LoteFarmacia[]
}

model Paciente {
  id          Int      @id @default(autoincrement())
  rut         String   @unique
  nombre      String
  apellido    String
  telefono    String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())

  movimientos MovimientoFarmacia[]
}

model MovimientoFarmacia {
  id           Int        @id @default(autoincrement())
  tipo         TipoMovimiento
  cantidad     Int
  lote         String?
  fechaVencimiento DateTime?
  proveedor    String?
  rutPaciente  String?
  pacienteId   Int?
  paciente     Paciente?  @relation(fields: [pacienteId], references: [id])
  observacion  String?
  fecha        DateTime   @default(now())
  medicamento  Medicamento @relation(fields: [medicamentoId], references: [id])
  medicamentoId Int
  usuario      User       @relation(fields: [usuarioId], references: [id])
  usuarioId    Int

  anulado      Boolean    @default(false)
  motivoAnulacion String?
  anulacionDeId Int?      @unique
  anulacionDe  MovimientoFarmacia?  @relation("AnulacionFarmacia", fields: [anulacionDeId], references: [id])
  anulacion    MovimientoFarmacia?  @relation("AnulacionFarmacia")
}

model ProductoBodegaHistorial {
  id          Int      @id @default(autoincrement())
  productoId  Int
  nombre      String
  categoriaId Int
  unidad      String
  stockMinimo Int
  validoDesde DateTime @default(now())
  validoHasta DateTime?
  producto    ProductoBodega  @relation(fields: [productoId], references: [id])
  categoria   CategoriaBodega @relation(fields: [categoriaId], references: [id])
}

model MedicamentoHistorial {
  id               Int      @id @default(autoincrement())
  medicamentoId    Int
  nombreGenerico   String
  nombreComercial  String?
  formaFarmaceutica String
  concentracion    String?
  unidad           String
  stockMinimo      Int
  categoriaId      Int
  validoDesde      DateTime @default(now())
  validoHasta      DateTime?
  medicamento      Medicamento       @relation(fields: [medicamentoId], references: [id])
  categoria        CategoriaFarmacia @relation(fields: [categoriaId], references: [id])
}

model LoteFarmacia {
  id                Int      @id @default(autoincrement())
  medicamentoId     Int
  numeroLote        String
  fechaVencimiento  DateTime?
  stockInicial      Int
  stockActual       Int
  fechaIngreso      DateTime  @default(now())
  proveedor         String?
  retirado          Boolean   @default(false)
  motivoRetiro      String?
  fechaRetiro       DateTime?
  medicamento       Medicamento @relation(fields: [medicamentoId], references: [id])
}

// ─── MÓDULO FLOTA ──────────────────────────────────────

enum TipoVehiculo {
  CAMIONETA
  SEDAN
  CAMION
  MAQUINARIA
  BUS
  OTRO
}

enum EstadoVehiculo {
  OPERATIVO
  EN_MANTENCION
  FUERA_SERVICIO
  DADO_DE_BAJA
}

enum EstadoSolicitud {
  PENDIENTE
  APROBADA
  RECHAZADA
  EN_CURSO
  CERRADA
}

enum TipoMantencion {
  PREVENTIVA
  CORRECTIVA
  EMERGENCIA
}

model Vehiculo {
  id                    Int            @id @default(autoincrement())
  patente               String         @unique
  marca                 String
  modelo                String
  anio                  Int
  tipo                  TipoVehiculo
  estado                EstadoVehiculo @default(OPERATIVO)
  kmActual              Int            @default(0)
  licenciasPermitidas   String[]       @default([]) // vacío = sin restricción de licencia
  observaciones         String?
  imagenUrl             String?
  activo                Boolean        @default(true)
  createdAt             DateTime       @default(now())

  solicitudes   SolicitudVehiculo[]
  mantenciones  MantencionVehiculo[]
  hojaVida      HojaVidaVehiculo[]
  documentos    DocumentoVehiculo[]
  vencimientos  VencimientoDocumentoVehiculo[]
  observacionesVehiculo ObservacionVehiculo[]
}

model DocumentoVehiculo {
  id          Int      @id @default(autoincrement())
  vehiculoId  Int
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id])
  nombre      String
  tipo        String
  url         String
  subidoPorId Int
  subidoPor   User     @relation(fields: [subidoPorId], references: [id])
  fecha       DateTime @default(now())
}

model SolicitudVehiculo {
  id              Int             @id @default(autoincrement())
  vehiculoId      Int
  vehiculo        Vehiculo        @relation(fields: [vehiculoId], references: [id])
  creadoPorId     Int
  creadoPor       User            @relation("CreadoPorFlota", fields: [creadoPorId], references: [id])
  conductorId     Int?
  conductorFlotaId Int?
  conductorFlota  ConductorFlota? @relation(fields: [conductorFlotaId], references: [id])
  conductorNombre String
  estado          EstadoSolicitud @default(PENDIENTE)
  destino         String
  proposito       String
  fechaSolicitud  DateTime        @default(now())
  aprobadoPorId   Int?
  aprobadoPor     User?           @relation("AprobacionFlota", fields: [aprobadoPorId], references: [id])
  fechaAprobacion DateTime?
  motivoRechazo   String?
  fechaCierre     DateTime?
  cerradoPorId    Int?
  cerradoPor      User?           @relation("CierreFlota", fields: [cerradoPorId], references: [id])

  checklist       ChecklistSolicitud?
  ordenServicio   OrdenServicioFlota?
  bitacora        BitacoraViaje?
  hojaVida        HojaVidaVehiculo[]
  fotosRevision   FotoRevisionVehiculo[]
  observacionesSolicitud ObservacionVehiculo[]
}

// Roster de choferes — independiente de la cuenta de login, se puede vincular opcionalmente
model ConductorFlota {
  id              Int       @id @default(autoincrement())
  nombre          String
  rut             String?
  numeroCaucion   String?
  numeroLicencia  String?
  tipoLicencia    String
  fechaLicencia   DateTime?
  activo          Boolean   @default(true)
  userId          Int?      @unique
  user            User?     @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())

  solicitudes SolicitudVehiculo[]
}

model FotoRevisionVehiculo {
  id          Int               @id @default(autoincrement())
  solicitudId Int
  solicitud   SolicitudVehiculo @relation(fields: [solicitudId], references: [id])
  tipo        String            // FRONTAL | LATERAL_IZQ | LATERAL_DER | POSTERIOR
  url         String
  fecha       DateTime          @default(now())
}

model ChecklistSolicitud {
  id           Int               @id @default(autoincrement())
  solicitudId  Int               @unique
  solicitud    SolicitudVehiculo @relation(fields: [solicitudId], references: [id])
  completadoEn DateTime          @default(now())

  respuestas ChecklistRespuesta[]
}

model ChecklistItem {
  id          Int      @id @default(autoincrement())
  categoria   String
  descripcion String
  orden       Int
  activo      Boolean  @default(true)

  respuestas ChecklistRespuesta[]
}

model ChecklistRespuesta {
  id          Int                @id @default(autoincrement())
  checklistId Int
  checklist   ChecklistSolicitud @relation(fields: [checklistId], references: [id])
  itemId      Int
  item        ChecklistItem      @relation(fields: [itemId], references: [id])
  valor       String
  observacion String?
}

model OrdenServicioFlota {
  id             Int               @id @default(autoincrement())
  solicitudId    Int               @unique
  solicitud      SolicitudVehiculo @relation(fields: [solicitudId], references: [id])
  horaSalidaEst  DateTime
  horaRetornoEst DateTime?
  folioFedoks    String?
  firmadaPorId   Int?
  firmadaPor     User?             @relation("FirmaOrdenFlota", fields: [firmadaPorId], references: [id])
  fechaFirma     DateTime?
  firmada        Boolean           @default(false)
}

model BitacoraViaje {
  id              Int               @id @default(autoincrement())
  solicitudId     Int               @unique
  solicitud       SolicitudVehiculo @relation(fields: [solicitudId], references: [id])
  kmSalida        Int
  kmLlegada       Int?
  horaRetornoReal DateTime?
  observacion     String?
  registradoEn    DateTime          @default(now())

  paradas ParadaViaje[]
}

model ParadaViaje {
  id             Int             @id @default(autoincrement())
  bitacoraId     Int
  bitacora       BitacoraViaje   @relation(fields: [bitacoraId], references: [id])
  km             Int
  descripcion    String?
  litros         Float?
  comprobanteRef String?
  fecha          DateTime        @default(now())
  pasajeros      PasajeroViaje[]
}

model PasajeroViaje {
  id        Int         @id @default(autoincrement())
  paradaId  Int
  parada    ParadaViaje @relation(fields: [paradaId], references: [id], onDelete: Cascade)
  nombre    String
  rut       String?
}

model HojaVidaVehiculo {
  id          Int                @id @default(autoincrement())
  vehiculoId  Int
  vehiculo    Vehiculo           @relation(fields: [vehiculoId], references: [id])
  solicitudId Int?
  solicitud   SolicitudVehiculo? @relation(fields: [solicitudId], references: [id])
  tipo        String
  descripcion String
  usuarioId   Int
  usuario     User               @relation(fields: [usuarioId], references: [id])
  fecha       DateTime           @default(now())
}

model MantencionVehiculo {
  id           Int            @id @default(autoincrement())
  vehiculoId   Int
  vehiculo     Vehiculo       @relation(fields: [vehiculoId], references: [id])
  tipo         TipoMantencion
  fecha        DateTime
  taller       String?
  costo        Float?
  kmAlMomento  Int?
  descripcion  String?
  registradoEn DateTime       @default(now())
  usuarioId    Int
  usuario      User           @relation(fields: [usuarioId], references: [id])
}

// Catálogo de tipos de documento configurable (SOAP/Rev. Técnica/Permiso vienen por defecto, esDefault=true)
model TipoDocumentoVehiculo {
  id               Int      @id @default(autoincrement())
  nombre           String
  diasAlertaDefault Int     @default(30)
  esDefault        Boolean  @default(false)
  activo           Boolean  @default(true)

  vencimientos VencimientoDocumentoVehiculo[]
}

// Vencimiento de un documento puntual de un vehículo
model VencimientoDocumentoVehiculo {
  id              Int                   @id @default(autoincrement())
  vehiculoId      Int
  vehiculo        Vehiculo              @relation(fields: [vehiculoId], references: [id])
  tipoDocumentoId Int
  tipoDocumento   TipoDocumentoVehiculo @relation(fields: [tipoDocumentoId], references: [id])
  fechaVencimiento DateTime
  diasAlerta      Int?                  // override del diasAlertaDefault del catálogo

  @@unique([vehiculoId, tipoDocumentoId])
}

// Observación sobre el estado del vehículo (ej. daño, neumático) — trazable hasta su cierre
model ObservacionVehiculo {
  id           Int                @id @default(autoincrement())
  vehiculoId   Int
  vehiculo     Vehiculo           @relation(fields: [vehiculoId], references: [id])
  solicitudId  Int?
  solicitud    SolicitudVehiculo? @relation(fields: [solicitudId], references: [id])
  origen       String             // CHECKLIST | MANUAL
  descripcion  String
  estado       String             @default("ABIERTA") // ABIERTA | CERRADA
  creadoPorId  Int?
  creadoPor    User?              @relation("CreadorObservacion", fields: [creadoPorId], references: [id])
  fecha        DateTime           @default(now())
  cerradoPorId Int?
  cerradoPor   User?              @relation("CierreObservacion", fields: [cerradoPorId], references: [id])
  fechaCierre  DateTime?

  notas    ObservacionNota[]
  archivos ObservacionArchivo[]
}

model ObservacionNota {
  id            Int                  @id @default(autoincrement())
  observacionId Int
  observacion   ObservacionVehiculo  @relation(fields: [observacionId], references: [id], onDelete: Cascade)
  texto         String
  autorId       Int
  autor         User                 @relation(fields: [autorId], references: [id])
  fecha         DateTime             @default(now())
}

model ObservacionArchivo {
  id            Int                  @id @default(autoincrement())
  observacionId Int
  observacion   ObservacionVehiculo  @relation(fields: [observacionId], references: [id], onDelete: Cascade)
  nombre        String
  url           String
  subidoPorId   Int
  subidoPor     User                 @relation(fields: [subidoPorId], references: [id])
  fecha         DateTime             @default(now())
}